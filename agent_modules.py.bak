import os
import requests
import json
from zhipuai import ZhipuAI

client = ZhipuAI(api_key=os.getenv("ZHIPUAI_API_KEY"))

def call_llm(prompt: str, max_tokens=2000) -> str:
    response = client.chat.completions.create(
        model="glm-4-flash",
        messages=[{"role": "user", "content": prompt}],
        max_tokens=max_tokens,
        temperature=0.4
    )
    return response.choices[0].message.content

def module0_preprocess(text: str) -> str:
    prompt = f"""你是书籍预处理专家。请基于以下文本，输出纯中文Markdown。**严格遵循以下格式，不要输出任何额外内容**：

### 目录
- 第一章 标题
- 第二章 标题
...（只输出章节名，不要输出页码或行号）

### 全书关键词
关键词1、关键词2、关键词3（最多20个，用中文顿号分隔）

### 作者核心主张（直接摘录原文完整句子，禁止省略号，每句以句号结束，**每类主张只保留一句，避免重复**）
- 原句1
- 原句2
...

**注意：不要输出版权信息、出版信息、献词、致谢等无关内容。如果同一意思的句子出现多次，只选择最精炼的一句。**

文本：
{text[:12000]}
"""
    return call_llm(prompt, max_tokens=1500)

def module1_insight(text: str) -> str:
    prompt = f"""你是哲学分析专家。请基于以下文本，用流畅的中文回答。**不要输出任何例子，直接回答问题**。

### 元问题
这本书试图解决的最根本问题是什么？它触发了什么基本需求？（用两到三句话清晰说明）

### 概念还原（用最基础的物理学/经济学原理，不要用生活例子）
选择书中1-3个核心概念，用最基本的原理（如熵增、供需、博弈）解释，避免比喻。

### 三大核心结论
作者最想让你相信的三个结论，每句不超过30字，直接陈述。

文本：
{text[:10000]}
"""
    return call_llm(prompt, max_tokens=1500)

def module2_critique(text: str) -> str:
    prompt = f"""你是批判性思维专家。请基于以下文本，**按照四个维度进行批判**，每个维度都要具体结合书中内容，禁止空泛。

### 1. 未说出的假设
作者依赖了哪些可能不成立的假设？请列出最多3个，并说明为什么这些假设可能有问题。

### 2. 逻辑张力
论证中有没有矛盾或薄弱环节？请指出具体的逻辑跳跃或证据不足的地方。

### 3. 被忽略的视角
有哪些重要的角度作者没有考虑？例如文化差异、时代背景、反例等。

### 4. 反常识质疑
如果站在作者的对立面，会如何反驳作者的核心观点？请给出一个有力的反论证。

文本：
{text[:10000]}
"""
    return call_llm(prompt, max_tokens=1500)

def module3_practice(text: str, user_context: str = "资源有限的初创团队") -> str:
    prompt = f"""你是实践教练。用户情境：{user_context}。请基于书中**具体**的道理、案例或原则，输出真正可操作的实践建议。禁止使用通用模板。

### 情境迁移
如果用户所处领域的基础假设被推翻，书中哪个**具体**的策略仍然有效？哪个会完全失效？请引用书中某个章节或例子说明。

### 24小时最小实验（必须与书中某个具体的道理强相关）
- **实验名称**：（直接关联书中某句话或某个案例）
- **书中依据**：摘录书中相关原句或描述（不超过50字）
- **具体步骤**（3-5步，每一步都要明确可执行，且与书中道理直接对应）：
  1. ...
  2. ...
  3. ...
- **成功指标**（可量化，且与书中预期一致）：

### 极端压力指令（预算0、单人、对巨头）
请从书中提取**唯一一个**仍可执行的策略，并给出每日15分钟的**具体行动指令**（必须引用书中原话或核心动作）。

文本：
{text[:10000]}
"""
    return call_llm(prompt, max_tokens=1500)


def module4_internalize(text: str) -> str:
    prompt = f"""你是学习内化专家。请基于书中内容，输出中文。

### 21天复习计划
设计一个间隔重复计划，每天只需5分钟。格式：
- 第1天：做...
- 第2天：做...
- 第7天：做...
- 第14天：做...
- 第21天：做...

### 模型网络类比
将本书核心与“二八定律”、“奥卡姆剃刀”、“复利效应”类比，分别说明异同点，并给出一个交叉应用场景。

### 费曼给孩子
用200字以内、无术语、生活化类比，向10岁孩子解释本书最核心的一个洞见。

文本：
{text[:10000]}
"""
    return call_llm(prompt, max_tokens=1500)

def generate_full_report(text: str, user_context: str = "资源有限的初创团队") -> dict:
    print("模块0：预处理...")
    pre = module0_preprocess(text)
    print("模块1：洞察本质...")
    ins = module1_insight(text)
    print("模块2：极致批判...")
    cri = module2_critique(text)
    print("模块3：极致实践...")
    pra = module3_practice(text, user_context)
    print("模块4：极致内化...")
    inter = module4_internalize(text)
    print("模块5：外部研究...")
    # 尝试从文本中提取书名和作者（简单启发式）
    lines = text.split('\n')
    title = ""
    author = ""
    for line in lines[:50]:
        if "书名" in line or "标题" in line:
            title = line.split("：")[-1].strip() if "：" in line else line
        if "作者" in line:
            author = line.split("：")[-1].strip() if "：" in line else line
    if not title:
        title = "本书"
    research = module5_research(title, author, text[:2000])
    return {
        "preprocess": pre,
        "insight": ins,
        "critique": cri,
        "practice": pra,
        "internalize": inter,
        "external_research": research
    }
 
def module5_research(book_title: str, author: str = "", text_snippet: str = "") -> str:
    """ Researcher Agent: 搜索书籍相关背景知识（作者生平、争议、时代背景）"""
    try:
        from ddgs import DDGS
    except ImportError:
        return "外部视角功能需要安装 ddgs 包：pip install ddgs"
    
    # 构造搜索查询
    query = f"{book_title} {author} 书评 争议 背景"
    if not author:
        query = f"{book_title} 书籍 背景"
    
    try:
        with DDGS() as ddgs:
            # 增加超时和重试
            results = list(ddgs.text(query, max_results=3, timeout=10))
            if not results:
                return "未找到相关背景信息。"
            output = "### 📚 外部视角（作者生平、争议、时代背景）\n\n"
            for r in results:
                output += f"- **{r['title']}**\n  {r['body']}\n\n"
            return output
    except Exception as e:
        return f"背景搜索失败：{str(e)}。请检查网络或稍后重试。"
